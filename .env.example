# ============================================================
# E-DÉFENCE V4 — Variables d'environnement
# Copier en .env et renseigner toutes les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# ===== DEBUG =====
DEBUG=false

# ===== SÉCURITÉ =====
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_HEX_CHARS_MINIMUM
# Générer : python -c "import secrets; print(secrets.token_urlsafe(32)[:32])"
AES_KEY=CHANGE_ME_32_CHARS_EXACTLY_HERE_
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== BASE DE DONNÉES =====
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://edefence:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/analyse_financiere
DATABASE_SYNC_URL=postgresql://edefence:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/analyse_financiere

# ===== REDIS =====
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# ===== ANTHROPIC / CLAUDE =====
# Obtenir sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ===== EMAIL SMTP =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@edefence.tech
SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
SMTP_FROM_EMAIL=noreply@edefence.tech
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true

# ===== CINETPAY (paiement mobile money) =====
# Obtenir sur https://cinetpay.com/developers
CINETPAY_API_KEY=CHANGE_ME_CINETPAY_API_KEY
CINETPAY_SITE_ID=CHANGE_ME_CINETPAY_SITE_ID

# ===== URLS =====
FRONTEND_URL=https://app.edefence.tech
BACKEND_URL=https://api.edefence.tech
ALLOWED_ORIGINS=["https://app.edefence.tech"]

# ===== UPLOADS =====
UPLOAD_DIR=/var/edefence/uploads
MAX_UPLOAD_SIZE_MB=50
