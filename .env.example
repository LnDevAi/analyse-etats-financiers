# ===== BASE DE DONNÉES =====
DATABASE_URL=postgresql+asyncpg://edefence:edefence@localhost:5432/analyse_financiere
DATABASE_SYNC_URL=postgresql://edefence:edefence@localhost:5432/analyse_financiere

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/0

# ===== SÉCURITÉ (CHANGER EN PRODUCTION) =====
SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_256_BITS_MINIMUM
AES_KEY=CHANGE_THIS_AES_KEY_32_BYTES_PROD

# ===== ANTHROPIC / CLAUDE =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== CORS =====
ALLOWED_ORIGINS=["http://localhost:3000","https://app.edefence.tech"]

# ===== UPLOADS =====
UPLOAD_DIR=/tmp/edefence_uploads
MAX_UPLOAD_SIZE_MB=50

# ===== FRONTEND =====
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
